{
	"manifest_version": 3,
	"default_locale": "en",
	"name": "Puda Web Clipper",
	"version": "1.0.0",
	"description": "Clip web pages as clean Markdown to your Obsidian vault — with AI summaries, highlights, and customizable templates.",
	"incognito": "not_allowed",
	"permissions": [
		"activeTab",
		"clipboardWrite",
		"commands",
		"contextMenus",
		"downloads",
		"offscreen",
		"storage",
		"scripting",
		"declarativeNetRequest"
	],
	"host_permissions": [
		"<all_urls>",
		"http://*/*",
		"https://*/*"
	],
	"action": {
		"default_popup": "popup.html"
	},
	"options_ui": {
		"page": "settings.html",
		"open_in_tab": true
	},
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": ["http://*/*", "https://*/*"],
			"js": ["browser-polyfill.min.js", "content.js"]
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["browser-polyfill.min.js", "style.css", "flatten-shadow-dom.js", "highlighter.css"],
			"extension_ids": ["*"],
			"matches": [ "*://*/*" ]
		}
	],
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self'"
	},
	"commands": {
		"_execute_action": {
			"suggested_key": {
				"default": "Ctrl+Shift+O",
				"mac": "Command+Shift+O"
			},
			"description": "__MSG_commandOpenClipper__"
		}
	}
}
