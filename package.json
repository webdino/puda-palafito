{
  "name": "puda-palafito",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome-first browser extension scaffold using WXT + React + TypeScript",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:chrome": "wxt build --browser chrome",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/chrome": "^0.1.37",
    "@types/mozilla-readability": "^0.2.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@webext-core/messaging": "^2.3.0",
    "debounce": "^3.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.3",
    "vitest": "4.0.18",
    "web-ext": "^9.3.0",
    "wxt": "^0.20.6"
  }
}