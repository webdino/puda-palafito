{
  "name": "puda-palafito",
  "version": "1.0.0",
  "private": true,
  "description": "ページ内容を自動要約してGoogle Driveにバックアップする Chrome拡張機能",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build --browser chrome",
    "zip": "wxt zip",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/chrome": "^0.1.37",
    "@types/dom-chromium-ai": "^0.0.14",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@webext-core/messaging": "^2.3.0",
    "@wxt-dev/storage": "^1.2.8",
    "debounce": "^3.0.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.577.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "4.1.0",
    "web-ext": "^9.3.0",
    "wxt": "^0.20.6"
  }
}
